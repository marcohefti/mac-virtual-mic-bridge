#!/usr/bin/env zsh
set -euo pipefail

if [[ "${MICBRIDGE_SKIP_VALIDATE_PRECOMMIT:-0}" == "1" ]]; then
  echo "[pre-commit] Skipping validate (MICBRIDGE_SKIP_VALIDATE_PRECOMMIT=1)"
  exit 0
fi

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "[pre-commit] Running ./scripts/validate.sh"
./scripts/validate.sh
